   "source": [
    "# Weight Tuning & Ablation Study\n",
    "\n",
    "After running 01_explore_dataset.ipynb and understanding the data:\n",
    "1. Test different weight combinations\n",
    "2. Check honeypot rate in top-100 under different configs\n",
    "3. Validate the final weights before generating submission\n",
    "\n",
    "**Target**: honeypot rate < 10% in top 100 (hard disqualification boundary)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.append('..')\n",
    "\n",
    "import gzip, json\n",
    "import pandas as pd\n",
    "from src.ranker.pipeline import RankingPipeline\n",
    "from src.signals.honeypot import is_honeypot\n",
    "\n",
    "# Load full dataset (or a 10k sample for fast tuning)\n",
    "print('Loading candidates...')\n",
    "with gzip.open('../data/raw/candidates.jsonl.gz', 'rt') as f:\n",
    "    all_candidates = [json.loads(line) for line in f if line.strip()]\n",
    "print(f'Loaded {len(all_candidates):,}')\n",
    "\n",
    "# Fast tuning subset\n",
    "sample = all_candidates[:10_000]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test default weights\n",
    "pipeline = RankingPipeline(top_n=100)\n",
    "results = pipeline.run(sample)\n",
    "\n",
    "# Check honeypot rate in top 100\n",
    "honeypot_count = 0\n",
    "for cid in results['candidate_id']:\n",
    "    # Look up the original candidate by ID\n",
    "    for c in sample:\n",
    "        if c.get('candidate_id', c.get('id')) == cid:\n",
    "            is_hp, _ = is_honeypot(c)\n",
    "            if is_hp:\n",
    "                honeypot_count += 1\n",
    "            break\n",
    "\n",
    "print(f'Honeypots in top 100: {honeypot_count}/100 ({honeypot_count}%)')\n",
    "print(f'Score range: {results[\"score\"].min():.2f} – {results[\"score\"].max():.2f}')\n",
    "print(results.head(10)[['rank', 'candidate_id', 'score', 'reasoning']])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
